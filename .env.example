# Kite Testnet
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
KITE_AGENT_PRIVATE_KEY=your_private_key_here
KITE_ATTESTATION_CONTRACT=
KITE_CHAIN_ID=2368

# Twelve Data
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# OpenRouter (used for Claude via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# LangSmith
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=tradeflow
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# x402 Data Server
X402_DATA_SERVER_URL=http://localhost:8001
X402_DATA_SERVER_WALLET=your_server_wallet_address_here

# Agent Config
AGENT_CYCLE_INTERVAL_SECONDS=30
MAX_POSITION_SIZE_USD=1000
MAX_DRAWDOWN_PCT=0.05
DAILY_LOSS_LIMIT_USD=500

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
